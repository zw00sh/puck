---
# Template for the gitignored `secrets.yml`. Copy it, fill in, and it is
# auto-loaded on every run (no CLI flags, no prompts):
#
#   cp secrets.yml.example secrets.yml      # then edit secrets.yml
#
# secrets.yml is gitignored; this .example is committed as documentation.
# CLI `-e var=...` still overrides any value here for ad-hoc, per-box runs.

# REQUIRED. The serial-console / break-glass password for the `pi` account.
# Provisioning aborts (assert in site.yml) if this is unset or empty.
pi_password: ""

# Reusable, TAGGED Tailscale auth key. Empty => the tailscale role is skipped,
# leaving any existing enrollment untouched. Revoke it once all units are enrolled.
ts_authkey: ""

# Pi-hole admin (web) password. Empty by default => auth disabled (open
# dashboard; the admin UI is tailnet-only via `tailscale serve`). Set a value to
# require a login. Only used when the optional pihole role is enabled.
pihole_admin_password: ""
